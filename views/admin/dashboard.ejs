<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <title>Admin Dashboard - AC-Rush</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    body {
      background: #0a0e27;
      color: #e2e8f0;
    }

    .admin-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }

    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      padding-bottom: 20px;
      border-bottom: 1px solid #2d3748;
    }

    .admin-header h1 {
      color: #00d4ff;
      font-size: 32px;
    }

    .admin-header .user-info {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .admin-header .logout-btn {
      padding: 8px 16px;
      background: #f56565;
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      text-decoration: none;
      font-weight: 500;
    }

    .admin-header .logout-btn:hover {
      background: #e53e3e;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .stat-card {
      background: #1a1f3a;
      border: 1px solid #2d3748;
      padding: 20px;
      border-radius: 8px;
      text-align: center;
    }

    .stat-card .number {
      color: #00d4ff;
      font-size: 28px;
      font-weight: bold;
      margin: 10px 0;
    }

    .stat-card .label {
      color: #a0aec0;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .action-buttons {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
    }

    .action-buttons a,
    .action-buttons button {
      padding: 12px 20px;
      background: #00d4ff;
      color: #0a0e27;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      text-decoration: none;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .action-buttons a:hover,
    .action-buttons button:hover {
      background: #00a8cc;
      box-shadow: 0 0 15px rgba(0, 212, 255, 0.3);
    }

    .problems-section {
      background: #1a1f3a;
      border: 1px solid #2d3748;
      border-radius: 8px;
      overflow: hidden;
    }

    .section-header {
      padding: 20px;
      border-bottom: 1px solid #2d3748;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .section-header h2 {
      color: #00d4ff;
      margin: 0;
    }

    .problems-table {
      width: 100%;
      border-collapse: collapse;
    }

    .problems-table thead {
      background: #0a0e27;
    }

    .problems-table th {
      padding: 15px 20px;
      text-align: left;
      color: #00d4ff;
      font-weight: 600;
      text-transform: uppercase;
      font-size: 12px;
      letter-spacing: 1px;
      border-bottom: 1px solid #2d3748;
    }

    .problems-table td {
      padding: 15px 20px;
      border-bottom: 1px solid #2d3748;
      color: #e2e8f0;
    }

    .problems-table tr:hover {
      background: #252a3a;
    }

    .difficulty-badge {
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      display: inline-block;
    }

    .difficulty-easy {
      background: #48bb78;
      color: white;
    }

    .difficulty-medium {
      background: #ed8936;
      color: white;
    }

    .difficulty-hard {
      background: #f56565;
      color: white;
    }

    .action-icons {
      display: flex;
      gap: 10px;
    }

    .action-btn {
      padding: 6px 12px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 600;
      transition: all 0.3s ease;
      text-decoration: none;
      display: inline-block;
    }

    .edit-btn {
      background: #4299e1;
      color: white;
    }

    .edit-btn:hover {
      background: #3182ce;
    }

    .delete-btn {
      background: #f56565;
      color: white;
      border: none;
    }

    .delete-btn:hover {
      background: #e53e3e;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #a0aec0;
    }

    .empty-state-icon {
      font-size: 48px;
      margin-bottom: 10px;
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <div>
        <h1>Admin Dashboard</h1>
      </div>
      <div class="user-info">
        <span>Welcome, <strong><%= username %></strong></span>
        <a href="/admin/logout" class="logout-btn">Logout</a>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="label">Total Problems</div>
        <div class="number"><%= problems.length %></div>
      </div>
      <div class="stat-card">
        <div class="label">Total Submissions</div>
        <div class="number"><%= totalSubmissions %></div>
      </div>
      <div class="stat-card">
        <div class="label">Easy Problems</div>
        <div class="number"><%= problems.filter(p => p.difficulty === 'Easy').length %></div>
      </div>
      <div class="stat-card">
        <div class="label">Medium Problems</div>
        <div class="number"><%= problems.filter(p => p.difficulty === 'Medium').length %></div>
      </div>
      <div class="stat-card">
        <div class="label">Hard Problems</div>
        <div class="number"><%= problems.filter(p => p.difficulty === 'Hard').length %></div>
      </div>
    </div>

    <div class="action-buttons">
      <a href="/admin/add-problem">+ Add New Problem</a>
      <a href="/admin/submissions">View Submissions</a>
    </div>

    <div class="problems-section">
      <div class="section-header">
        <h2>Problems</h2>
      </div>

      <% if (problems.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">📚</div>
          <p>No problems added yet</p>
          <a href="/admin/add-problem" style="color: #00d4ff; text-decoration: underline;">Create your first problem</a>
        </div>
      <% } else { %>
        <table class="problems-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Difficulty</th>
              <th>Category</th>
              <th>Examples</th>
              <th>Checker</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% problems.forEach(problem => { %>
              <tr>
                <td><strong><%= problem.title %></strong></td>
                <td>
                  <span class="difficulty-badge difficulty-<%= problem.difficulty.toLowerCase() %>">
                    <%= problem.difficulty %>
                  </span>
                </td>
                <td><%= problem.category %></td>
                <td><%= problem.examples.length %></td>
                <td>
                  <% if (problem.useCustomChecker) { %>
                    <span style="color: #48bb78;">✓ Custom</span>
                  <% } else { %>
                    <span style="color: #a0aec0;">Standard</span>
                  <% } %>
                </td>
                <td>
                  <div class="action-icons">
                    <a href="/admin/edit-problem/<%= problem._id %>" class="action-btn edit-btn">Edit</a>
                    <form method="POST" action="/admin/delete-problem/<%= problem._id %>" style="display: inline;" onsubmit="return confirm('Delete this problem?');">
                      <button type="submit" class="action-btn delete-btn">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</body>
</html>
